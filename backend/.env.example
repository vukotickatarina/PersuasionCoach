# Environment variables for Render (or other production deployment).
# Set these in Render → Environment, NOT in this file.
# For local dev, use application-local.properties instead (see .example template).
# NEVER commit a .env file with real values.

# --- PostgreSQL (Render provides these when you attach a Postgres database) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://your-host.render.com/your_db_name
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# --- JWT secret: Base64-encoded, must decode to at least 32 bytes ---
# Generate one: openssl rand -base64 48
JWT_SECRET=your_base64_jwt_secret_min_32_bytes_when_decoded

# --- CORS: comma-separated list of allowed frontend origins ---
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# --- Anthropic Claude AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Mail (optional) ---
MAIL_PASSWORD=your_gmail_app_password_here

# --- Gemini AI (not in use) ---
GEMINI_API_KEY=your_gemini_api_key_here
