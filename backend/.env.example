# Environment varijable za Persuasion Coach backend
# Kopiraj kao .env ili postavi kao System Environment Variables (Windows) /
# IntelliJ Run Configuration → Environment Variables.
# NIKAD ne commituj .env fajl sa stvarnim vrijednostima.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DB_PASSWORD=your_postgres_password_here
JWT_SECRET=your_jwt_secret_min_32_chars_here
MAIL_PASSWORD=your_gmail_app_password_here
